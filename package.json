{
  "name": "connect-feishu-bot",
  "version": "0.3.0",
  "description": "Full-featured Feishu/Lark bot SDK. QR setup, CardKit streaming, emoji reactions, messaging, mentions. 飞书机器人 SDK：扫码创建、流式卡片、表情反应、消息收发、@提及。",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "connect-feishu-bot": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./streaming": {
      "types": "./dist/streaming/index.d.ts",
      "import": "./dist/streaming/index.js"
    },
    "./reactions": {
      "types": "./dist/reactions/index.d.ts",
      "import": "./dist/reactions/index.js"
    },
    "./bot": {
      "types": "./dist/bot/index.d.ts",
      "import": "./dist/bot/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "tsc"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "feishu",
    "lark",
    "bot",
    "飞书",
    "机器人",
    "qr-code",
    "chatbot",
    "streaming",
    "cardkit",
    "interactive-card"
  ],
  "license": "MIT",
  "dependencies": {
    "qrcode-terminal": "^0.12.0"
  },
  "peerDependencies": {
    "@larksuiteoapi/node-sdk": ">=1.59.0"
  },
  "peerDependenciesMeta": {
    "@larksuiteoapi/node-sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@larksuiteoapi/node-sdk": "^1.60.0",
    "@types/node": "^20.19.37",
    "typescript": "^5.9.3"
  }
}
