{
  "name": "connect-feishu-bot",
  "version": "0.1.0",
  "description": "Create a Feishu/Lark bot by scanning a QR code. 扫码一键创建飞书机器人。",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "connect-feishu-bot": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "tsc"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "feishu",
    "lark",
    "bot",
    "飞书",
    "机器人",
    "qr-code",
    "chatbot"
  ],
  "license": "MIT",
  "dependencies": {
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^20.0.0"
  }
}
